# Application Settings
APP_NAME="Q400 Study"
APP_VERSION="1.0.0"
APP_DEBUG=true
APP_TIMEZONE="UTC"
APP_BASE_URL="http://localhost/q400-study/public"

# Session Settings
SESSION_NAME="q400_study_session"
SESSION_LIFETIME=3600

# Database Configuration
DB_DRIVER="mysql"
DB_HOST="localhost"
DB_PORT=3306
DB_DATABASE="q400_study"
DB_USERNAME="root"
DB_PASSWORD=""
DB_CHARSET="utf8mb4"
DB_COLLATION="utf8mb4_unicode_ci"

# File Storage
UPLOAD_PATH="./storage/uploads"
PDF_PATH="./storage/pdfs"
LOG_PATH="./storage/logs"

# Security
CSRF_ENABLED=true
ENCRYPTION_KEY="change-this-to-a-random-32-character-key"

# Features
CACHE_ENABLED=false
CACHE_DRIVER="file"
QUERY_LOG_ENABLED=true

# Pagination
PER_PAGE=15
