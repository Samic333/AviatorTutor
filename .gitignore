.env
.env.backup
.DS_Store
Thumbs.db

# Internal planning artefacts — overhaul briefs / PDFs not for prod.
Prompts/

# Per-environment config overrides (loaded by config/*.php if present)
config/*.local.php

# Logs and runtime state
*.log
storage/logs/*
storage/cache/*
storage/sessions/*
storage/uploads/*
!storage/logs/.gitkeep
!storage/cache/.gitkeep
!storage/sessions/.gitkeep
!storage/uploads/.gitkeep

# IDE
.idea/
.vscode/

# Local Node toolchain (only used for optional CSS build)
node_modules/

# Composer-installed dependencies — pulled by `composer install` on the
# server during deploy, not committed to the repo.
vendor/
composer.lock

# One-shot deploy seed scripts. These contain a hard-coded secret key in
# the file itself and grant admin role on hit, so they must never enter
# git history. Drop on the server, run once, the script self-deletes.
public/setup_seed.php
public/setup_*.php
